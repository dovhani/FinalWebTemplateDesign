---
interface SubNavItem {
    title: string;
    href: string;
}

interface Props {
    items: SubNavItem[];
    activeHref?: string;
    className?: string;
}

const { items, activeHref, className = "" } = Astro.props;
---

<div class={`subnav-container ${className}`}>
    <div class="subnav-inner max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <ul class="subnav-list">
            {items.map(item => (
                <li>
                    <a
                        href={item.href}
                        class={`subnav-link ${activeHref === item.href ? 'active' : ''}`}
                    >
                        <svg class="subnav-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                        </svg>
                        {item.title}
                    </a>
                </li>
            ))}
        </ul>
    </div>
</div>

<style>
    .subnav-container {
        position: relative;
        width: 100%;
        z-index: 80;
        margin-top: calc(5% + 10px);
        margin-bottom: 30px;
    }

    .subnav-inner {
        background: transparent;
        padding-top: 25px;
        padding-bottom: 1.5rem;
    }

    .subnav-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .subnav-list li {
        flex: 1 1 0;
        min-width: 140px;
        max-width: 220px;
    }

    .subnav-link {
        display: inline-flex;
        width: 100%;
        align-items: center;
        justify-content: center;
        gap: 0.375rem;
        padding: 12px;
        min-width: 10.5rem;
        font-family: 'Lato', sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        white-space: nowrap;
        border-radius: 9999px;
        border: 1px solid #e2e8f0;
        color: #334155;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .subnav-link:hover {
        border-color: #543717;
        color: #543717;
        background: #fff1f2;
    }

    .subnav-link.active {
        background: #543717;
        color: white;
        border-color: #543717;
    }

    .subnav-arrow {
        width: 0.75rem;
        height: 0.75rem;
        opacity: 0.5;
        transition: opacity 0.2s;
        flex-shrink: 0;
    }

    .subnav-link:hover .subnav-arrow,
    .subnav-link.active .subnav-arrow {
        opacity: 1;
    }

    /* ── Mobile ── */
    @media (max-width: 640px) {
        .subnav-container {
            margin-bottom: 20px !important;
        }

        .subnav-list {
            gap: 0.5rem;
        }

        .subnav-link {
            min-width: 0;
            flex: 1 1 calc(50% - 0.5rem);
            padding: 9.6px 10px;
            font-size: 0.6rem;
            letter-spacing: 0.12em;
        }
    }

    @media (max-width: 380px) {
        .subnav-link {
            flex: 1 1 100%;
        }
    }
</style>
