---
const currentYear = new Date().getFullYear();
const enrolmentYear = currentYear + 1; // Applications are usually for the next academic year


const quickLinks = [
    { title: 'Home',        href: '/' },
    { title: 'About Us',    href: '/about' },
    { title: 'Our School',  href: '/our-school' },
    { title: 'Enrolment',   href: '/enrolment' },
    { title: 'Policies & Documents', href: '/policies' },
    { title: 'Gallery',     href: '/gallery' },
    { title: 'Contact Us',  href: '/contact' },
];

const contactItems = [
    {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                     d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0
                        1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round"
                     stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
        label: 'Mukondeni, Mulima Tribal<br/>Limpopo, South Africa',
    },
    {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                     d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0
                        01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0
                        011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3
                        14.284 3 6V5z"/>`,
        label: '(+27) 71 692 4080',
    },
    {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                     d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0
                        00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
        label: 'info@lotsha.edu.za',
    },
    {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                     d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
        label: 'Mon – Fri &nbsp;·&nbsp; 7:30 AM – 4:00 PM',
    },
];
---

<footer class="ft-footer">

    <!-- ── Maroon top accent bar ── -->
    <div class="ft-top-bar">
        <div class="ft-top-bar-inner">
            <span class="ft-top-label">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 0v9m0 0l3.5-3.5M12 12l-3.5-3.5" />
                </svg>
                Nurturing Minds · Shaping Leaders · Building Excellence
            </span>
            <div class="ft-top-links">
                <a href="/enrolment" class="ft-top-cta">Apply for {enrolmentYear} →</a>
            </div>
        </div>
    </div>

    <!-- ── Main footer body ── -->
    <div class="ft-body">

        <!-- Ghost watermark -->
        <div class="ft-watermark" aria-hidden="true">LOTSHA</div>

        <div class="ft-grid">

            <!-- Col 1: School identity -->
            <div class="ft-col ft-col--identity">
                <p class="ft-eyebrow">Est. 1967</p>
                <h2 class="ft-school-name">
                    Lotsha
                    <span class="ft-school-sub">Primary School</span>
                </h2>
                <div class="ft-name-rule"></div>
                <p class="ft-tagline">
                    A forge of future leaders rooted in community, driven by purpose, 
                    and committed to transforming lives through quality education in 
                    Limpopo, South Africa.
                </p>

                <!-- Social icons -->
                <div class="ft-socials">
                    <!-- Facebook -->
                    <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="ft-social" aria-label="Facebook">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                        </svg>
                    </a>
                    <!-- Twitter/X -->
                    <a href="https://www.twitter.com" target="_blank" rel="noopener noreferrer" class="ft-social" aria-label="Twitter">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0
                                     01 3 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0
                                     00-.08-.83A7.72 7.72 0 0023 3z"/>
                        </svg>
                    </a>
                    <!-- Instagram -->
                    <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" class="ft-social" aria-label="Instagram">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                                  stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zM17.5 6.5h.01"/>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Col 2: Quick links -->
            <div class="ft-col">
                <h3 class="ft-col-heading">Quick Links</h3>
                <ul class="ft-links">
                    {quickLinks.map(link => (
                        <li>
                            <a href={link.href} class="ft-link">
                                <span class="ft-link-rule"></span>
                                {link.title}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- Col 3: Contact -->
            <div class="ft-col">
                <h3 class="ft-col-heading">Contact Us</h3>
                <ul class="ft-contact-list">
                    {contactItems.map(item => (
                        <li class="ft-contact-item">
                            <div class="ft-contact-icon">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"
                                     set:html={item.icon} />
                            </div>
                            <span class="ft-contact-label" set:html={item.label} />
                        </li>
                    ))}
                </ul>
            </div>

            <!-- Col 4: Newsletter -->
            <div class="ft-col">
                <h3 class="ft-col-heading">Newsletter</h3>
                <p class="ft-newsletter-desc">
                    Be the first to hear about events, announcements, and achievements from Lotsha.
                </p>
                <form class="ft-newsletter-form newsletter-form">
                    <div class="ft-input-wrap">
                        <svg class="ft-input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        <input
                            type="email"
                            placeholder="Your email address"
                            class="ft-input"
                            required
                        />
                    </div>
                    <button type="submit" class="ft-subscribe-btn">
                        Subscribe
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                        </svg>
                    </button>
                </form>

                <!-- Accreditation badges -->
                <div class="ft-accreditation">
                    <span class="ft-accred-badge">DBE Registered</span>
                    <span class="ft-accred-badge">NSC Certified</span>
                </div>
            </div>

        </div>
    </div>

    <!-- ── Bottom bar ── -->
    <div class="ft-bottom">
        <div class="ft-bottom-inner">
            <p class="ft-copyright">
                &copy; {currentYear} Lotsha Primary School. All rights reserved.
            </p>
            <div class="ft-bottom-links">
                <a href="/policies" class="ft-bottom-link">Privacy Policy</a>
                <a href="/policies" class="ft-bottom-link">Terms of Use</a>
                <a href="/sitemap.xml" class="ft-bottom-link">Sitemap</a>
            </div>
        </div>
    </div>

</footer>

<style>
  /* ════════════════════════════════════════
     FOOTER — Premium (ft-*)
     ════════════════════════════════════════ */

  .ft-footer {
    background: #060b14;
    color: #fff;
    position: relative;
    overflow: hidden;
    margin-top: 0;
  }

  /* ── Top accent bar ── */
  .ft-top-bar {
    background: linear-gradient(135deg, #3a2610 0%, #543717 50%, #5e3f1a 100%);
    position: relative;
    overflow: hidden;
  }
  .ft-top-bar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .ft-top-bar-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.9rem clamp(1.5rem, 5vw, 4rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    position: relative;
  }
  .ft-top-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
  }
  .ft-top-label svg {
    width: 0.9rem;
    height: 0.9rem;
    color: #deb056;
    flex-shrink: 0;
  }
  .ft-top-links { flex-shrink: 0; }
  .ft-top-cta {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #deb056;
    text-decoration: none;
    border-bottom: 1px solid rgba(253,230,138,0.35);
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .ft-top-cta:hover { color: #fff; border-color: rgba(255,255,255,0.5); }

  /* ── Main body ── */
  .ft-body {
    position: relative;
    max-width: 80rem;
    margin: 0 auto;
    padding: 5rem clamp(1.5rem, 5vw, 4rem) 4rem;
  }

  /* Ghost watermark */
  .ft-watermark {
    position: absolute;
    bottom: -2rem;
    right: clamp(1.5rem, 5vw, 4rem);
    font-family: 'Bodoni Moda', serif;
    font-size: clamp(6rem, 14vw, 12rem);
    font-weight: 100;
    letter-spacing: 0.15em;
    color: #fff;
    opacity: 0.018;
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  /* ── Grid ── */
  .ft-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.1fr 1.2fr;
    gap: clamp(2rem, 4vw, 4rem);
    position: relative;
  }

  /* ── Column shared ── */
  .ft-col { display: flex; flex-direction: column; gap: 0; }
  .ft-col-heading {
    font-family: 'Lato', sans-serif;
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: #cb8f24;
    margin: 0 0 2rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .ft-col-heading::after {
    content: '';
    display: block;
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(245,158,11,0.3) 0%, transparent 100%);
  }

  /* ── Identity column ── */
  .ft-eyebrow {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: #543717;
    margin: 0 0 0.6rem;
  }
  .ft-school-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.1;
    margin: 0 0 0.3rem;
    display: flex;
    flex-direction: column;
  }
  .ft-school-sub {
    font-size: 0.75em;
    font-weight: 300;
    color: #64748b;
    letter-spacing: 0.08em;
  }
  .ft-name-rule {
    width: 2.5rem;
    height: 2px;
    background: linear-gradient(90deg, #543717, #cb8f24);
    margin: 1rem 0 1.2rem;
    border-radius: 2px;
  }
  .ft-tagline {
    font-family: 'Lato', sans-serif;
    font-size: 0.75rem;
    color: #475569;
    line-height: 1.75;
    margin: 0 0 1.75rem;
    font-weight: 300;
  }

  /* Social icons */
  .ft-socials {
    display: flex;
    gap: 0.6rem;
    margin-top: auto;
  }
  .ft-social {
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid #1e293b;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #475569;
    text-decoration: none;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
  }
  .ft-social:hover {
    border-color: #543717;
    color: #fff;
    background: rgba(var(--brand-rgb),0.15);
  }
  .ft-social svg { width: 0.85rem; height: 0.85rem; }

  /* ── Quick links ── */
  .ft-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .ft-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Lato', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: #475569;
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s ease, gap 0.25s ease;
    padding: 0.2rem 0;
  }
  .ft-link:hover { color: #fff; gap: 0.9rem; }
  .ft-link-rule {
    display: inline-block;
    width: 1rem;
    height: 1px;
    background: #1e293b;
    flex-shrink: 0;
    transition: width 0.25s ease, background 0.25s ease;
  }
  .ft-link:hover .ft-link-rule {
    width: 1.75rem;
    background: #543717;
  }

  /* ── Contact list ── */
  .ft-contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .ft-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .ft-contact-icon {
    width: 1.75rem;
    height: 1.75rem;
    background: rgba(var(--brand-rgb),0.10);
    border: 1px solid rgba(var(--brand-rgb),0.20);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #543717;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .ft-contact-item:hover .ft-contact-icon {
    background: rgba(var(--brand-rgb),0.22);
    border-color: rgba(var(--brand-rgb),0.45);
  }
  .ft-contact-icon svg { width: 0.75rem; height: 0.75rem; }
  .ft-contact-label {
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    color: #475569;
    line-height: 1.65;
    font-weight: 300;
    padding-top: 0.15rem;
  }

  /* ── Newsletter ── */
  .ft-newsletter-desc {
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    color: #475569;
    line-height: 1.7;
    margin: 0 0 1.25rem;
    font-weight: 300;
  }
  .ft-newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .ft-input-wrap {
    position: relative;
  }
  .ft-input-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 0.85rem;
    height: 0.85rem;
    color: #334155;
    pointer-events: none;
  }
  .ft-input {
    width: 100%;
    padding: 0.7rem 0.75rem 0.7rem 2.25rem;
    background: #0f172a;
    border: 1px solid #1e293b;
    color: #cbd5e1;
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    outline: none;
    transition: border-color 0.25s ease, background 0.25s ease;
    box-sizing: border-box;
  }
  .ft-input::placeholder { color: #334155; }
  .ft-input:focus {
    border-color: #543717;
    background: #111827;
  }
  .ft-subscribe-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    background: #543717;
    color: #fff;
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.2s ease;
  }
  .ft-subscribe-btn:hover {
    background: #3a2610;
    transform: translateY(-1px);
  }
  .ft-subscribe-btn svg { width: 0.8rem; height: 0.8rem; }

  /* Accreditation badges */
  .ft-accreditation {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .ft-accred-badge {
    font-family: 'Lato', sans-serif;
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #334155;
    border: 1px solid #1e293b;
    padding: 0.25rem 0.6rem;
  }

  /* ── Bottom bar ── */
  .ft-bottom {
    border-top: 1px solid #0f172a;
    background: #030712;
  }
  .ft-bottom-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 1.25rem clamp(1.5rem, 5vw, 4rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .ft-copyright {
    font-family: 'Lato', sans-serif;
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1e293b;
    margin: 0;
  }
  .ft-bottom-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .ft-bottom-link {
    font-family: 'Lato', sans-serif;
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1e293b;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ft-bottom-link:hover { color: #475569; }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .ft-grid { grid-template-columns: 1fr 1fr; gap: 3rem 2.5rem; }
    .ft-col--identity { grid-column: span 2; }
  }
  @media (max-width: 640px) {
    .ft-grid { grid-template-columns: 1fr; }
    .ft-col--identity { grid-column: span 1; }
    .ft-top-bar-inner { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .ft-bottom-inner { flex-direction: column; gap: 0.75rem; }
  }
</style>

<script>
  const newsletterForm = document.querySelector('.newsletter-form');
  if (newsletterForm) {
    newsletterForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = newsletterForm.querySelector('.ft-subscribe-btn') as HTMLButtonElement;
      if (btn) {
        btn.textContent = '✓ Subscribed!';
        btn.style.background = '#15803d';
        setTimeout(() => {
          btn.textContent = 'Subscribe';
          btn.style.background = '';
        }, 3000);
      }
      (newsletterForm as HTMLFormElement).reset();
    });
  }
</script>
