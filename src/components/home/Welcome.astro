---
import { Image } from 'astro:assets';
const currentYear = new Date().getFullYear();
const yearsOfExcellence = currentYear - 1967;
---
<!-- Section label -->
        <div id="welcome-header" class="ws-section-label scroll-mt-[120px]">
            <span class="ws-label-eyebrow">Est. 1967 · Limpopo, South Africa</span>
            <h2 class="ws-label-heading">Welcome to Lotsha</h2>
            <div class="ws-label-rule"></div>
        </div>

        <!-- Mission banner -->
        <div class="ws-mission-banner">
            <div class="ws-mission-text">
                <svg class="ws-mission-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 0v9m0 0l3.5-3.5M12 12l-3.5-3.5" />
                </svg>
                <span>Our Mission</span>
            </div>
            <p class="ws-mission-statement">
                To equip every learner with knowledge, values, and resilience — transforming raw potential 
                into purposeful achievement for a changing South Africa and a global future.
            </p>
        </div>

        <!-- Principal + Story two-column -->
        <section class="ws-main-grid">

            <!-- LEFT: Principal image card -->
            <div class="ws-principal-col ws-reveal">
                <div class="ws-principal-frame">

                    <!-- Floating accent badge -->
                    <div class="ws-badge">
                        <svg class="ws-badge-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                        </svg>
                        <span>{yearsOfExcellence} Years of Excellence</span>
                    </div>

                    <!-- Photo -->
                        <Image
                            src="https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_auto,c_fill,g_face,w_800,h_1000/v1773823589/principal_qqvw0x.avif"
                            alt="Mashamba A.G — Principal"
                            width={800}
                            height={1000}
                            class="ws-principal-photo"
                            loading="lazy"
                            decoding="async"
                        />
                        <!-- Subtle color overlay on hover -->
                        <div class="ws-photo-sheen"></div>
                    </div>

                    <!-- Identity card -->
                    <div class="ws-principal-card">
                        <div class="ws-principal-card-inner">
                            <p class="ws-principal-name">Mashamba A.G</p>
                            <div class="ws-principal-divider">
                                <span class="ws-principal-rule"></span>
                                <span class="ws-principal-role">Principal · Lotsha Primary</span>
                            </div>
                            <p class="ws-principal-years">Leading with vision since 2023</p>
                        </div>
                        <!-- Decorative maroon bar -->
                        <div class="ws-principal-card-bar"></div>
                    </div>

                    <!-- Background geometric accent -->
                    <div class="ws-geo-accent"></div>
                </div>
            </div>

            <!-- RIGHT: Story + values -->
            <div class="ws-story-col">

                <!-- Eyebrow + heading -->
                <div class="ws-story-header ws-reveal">
                    <span class="ws-eyebrow">Since 1967</span>
                    <h2 class="ws-story-heading">
                        Inspiring Minds,<br/>
                        <em class="ws-story-em">Shaping</em> Exceptional Futures
                    </h2>
                </div>

                <!-- Principal's spoken word quote -->
                <blockquote class="ws-quote ws-reveal">
                    <div class="ws-quote-mark">&ldquo;</div>
                    <p class="ws-quote-body">
                        Every learner who walks through these gates carries within them a story 
                        that deserves to be heard, celebrated, and elevated. At Lotsha, 
                        we do not just teach — we ignite. We build character alongside curriculum, 
                        and courage alongside academics. This school is not merely a place of learning;
                        it is a forge of future leaders.
                    </p>
                    <footer class="ws-quote-footer">
                        <span class="ws-quote-sig">— Mashamba A.G, Principal</span>
                    </footer>
                </blockquote>

                <!-- Value pillars -->
                <div class="ws-pillars ws-reveal">
                    <div class="ws-pillar">
                        <div class="ws-pillar-icon-wrap">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="ws-pillar-title">Academic Excellence</h3>
                            <p class="ws-pillar-desc">Rigorous, future-focused curriculum equipping learners for university and beyond.</p>
                        </div>
                    </div>

                    <div class="ws-pillar">
                        <div class="ws-pillar-icon-wrap">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="ws-pillar-title">Community & Character</h3>
                            <p class="ws-pillar-desc">Cultivating integrity, empathy, and ubuntu as the bedrock of every graduate.</p>
                        </div>
                    </div>

                    <div class="ws-pillar">
                        <div class="ws-pillar-icon-wrap">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="ws-pillar-title">Innovation & Sport</h3>
                            <p class="ws-pillar-desc">Arts, athletics, and technology programs to develop every dimension of the whole learner.</p>
                        </div>
                    </div>
                </div>

                <!-- CTA -->
                <div class="ws-cta ws-reveal">
                    <a href="/about" class="ws-cta-link">
                        Discover Our Story
                        <span class="ws-cta-arrow">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </span>
                    </a>
                    <a href="/enrolment" class="ws-cta-secondary">
                        Apply Now &rarr;
                    </a>
                </div>
            </div>
        </section>

        
<style>
/* ════ WELCOME SECTION (ws-*) ════ */
/* ── Section label header ── */
  .ws-section-label {
    text-align: center;
    padding: 5rem 1rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }
  .ws-label-eyebrow {
    font-family: 'Lato', sans-serif;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: #543717;
  }
  .ws-label-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    color: #0f172a;
    letter-spacing: 0.04em;
    line-height: 1.1;
    margin: 0;
  }
  .ws-label-rule {
    width: 3rem;
    height: 2px;
    background: linear-gradient(90deg, #543717, #cb8f24);
    margin-top: 0.5rem;
    border-radius: 2px;
  }

  /* ── Mission banner ── */
  .ws-mission-banner {
    background: linear-gradient(135deg, #3a2610 0%, #543717 50%, #5e3f1a 100%);
    color: #fff;
    padding: 2rem clamp(1.5rem, 5vw, 4rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 3rem;
    margin-bottom: 3.5rem;
    position: relative;
    overflow: hidden;
  }
  .ws-mission-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .ws-mission-text {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }
  .ws-mission-icon {
    width: 1.1rem;
    height: 1.1rem;
    color: #deb056;
    flex-shrink: 0;
  }
  .ws-mission-text span {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #deb056;
    white-space: nowrap;
  }
  .ws-mission-statement {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 300;
    color: rgba(255,255,255,0.88);
    line-height: 1.6;
    letter-spacing: 0.01em;
    flex: 1;
    min-width: 0;
    margin: 0;
    position: relative;
  }

  /* ── Main two-column grid ── */
  .ws-main-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    margin-bottom: 5rem;
  }

  /* ── Principal column ── */
  .ws-principal-col { position: relative; }
  .ws-principal-frame {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Floating badge */
  .ws-badge {
    position: absolute;
    top: -1rem;
    right: -1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 1.25rem;
    border-radius: 9999px;
    border: 1px solid rgba(203, 143, 36, 0.35);
    background: rgba(203, 143, 36, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #cb8f24;
    gap: 0.4rem;
    z-index: 10;
  }
  .ws-badge-icon {
    width: 0.9rem;
    height: 0.9rem;
    color: #cb8f24;
    flex-shrink: 0;
  }
  .ws-badge span {
    color: #cb8f24;
    white-space: nowrap;
  }

  /* Photo */
  .ws-principal-photo-wrap {
    position: relative;
    overflow: hidden;
    width: 100%;
    display: flex;
  }
  .ws-principal-photo {
    width: 100%;
    height: auto;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    display: block;
  }
  .ws-principal-photo-wrap:hover .ws-principal-photo { transform: scale(1.04); }
  .ws-photo-sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(var(--brand-rgb),0.35) 100%);
    pointer-events: none;
  }

  /* Identity card below photo */
  .ws-principal-card {
    display: flex;
    align-items: stretch;
    background: #fff;
    border: 1px solid #f1f5f9;
    box-shadow: 0 16px 48px rgba(15,23,42,0.10);
    position: relative;
    overflow: hidden;
  }
  .ws-principal-card-inner {
    flex: 1;
    padding: 1.25rem 1.5rem;
  }
  .ws-principal-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: #f97316 !important;
    margin: 0 0 0.4rem;
    line-height: 1.2;
  }
  .ws-principal-divider {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.3rem;
  }
  .ws-principal-rule {
    display: inline-block;
    width: 1.5rem;
    height: 2px;
    background: #cb8f24;
    flex-shrink: 0;
  }
  .ws-principal-role {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #543717;
  }
  .ws-principal-years {
    font-family: 'Lato', sans-serif;
    font-size: 0.7rem;
    color: #94a3b8;
    margin: 0;
    letter-spacing: 0.05em;
  }
  .ws-principal-card-bar {
    display: none;
  }

  /* Geometric background accent */
  .ws-geo-accent {
    position: absolute;
    bottom: -2rem;
    left: -2rem;
    width: 8rem;
    height: 8rem;
    border: 1px solid #fee2e2;
    transform: rotate(15deg);
    pointer-events: none;
    z-index: -1;
  }

  /* ── Story column ── */
  .ws-story-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 1rem;
  }

  .ws-story-header {}
  .ws-eyebrow {
    display: inline-block;
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: #543717;
    border-right: 2px solid #cb8f24;
    padding-right: 0.75rem;
    margin-bottom: 0.8rem;
  }
  .ws-story-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 400;
    color: #0f172a;
    line-height: 1.15;
    margin: 0;
    letter-spacing: 0.01em;
  }
  .ws-story-em {
    font-style: italic;
    color: #543717;
    font-weight: 300;
  }

  /* ── Principal quote ── */
  .ws-quote {
    position: relative;
    background: #fff; /* White background */
    border-left: 4px solid #cb8f24; /* Mustard color edge */
    padding: 1.5rem 1.5rem 1.5rem 2.5rem;
    margin: 0;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
  }
  .ws-quote-mark {
    position: absolute;
    top: -0.5rem;
    left: 0.75rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem;
    line-height: 1;
    color: #cb8f24;
    opacity: 0.25;
    pointer-events: none;
    user-select: none;
  }
  .ws-quote-body {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: 500;
    font-style: italic;
    color: var(--brand-primary); /* Dark Brown text */
    line-height: 1.75;
    margin: 0 0 0.75rem;
    position: relative;
    z-index: 2;
  }
  .ws-quote-footer { 
    margin-top: 1.25rem; 
    position: relative; 
    z-index: 2; 
    background: var(--brand-primary); 
    display: inline-block;
    padding: 0.6rem 1.2rem;
    border-radius: 0.4rem;
  }
  .ws-quote-sig {
    font-family: 'Lato', sans-serif;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brand-light) !important; /* White text on brown bg */
  }

  /* ── Value pillars ── */
  .ws-pillars {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .ws-pillar {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid #f1f5f9;
    background: #fff;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }
  .ws-pillar:hover {
    border-color: var(--brand-border);
    box-shadow: 0 8px 24px rgba(var(--brand-rgb),0.08);
    transform: translateX(4px);
  }
  .ws-pillar-icon-wrap {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--brand-light);
    border: 1px solid #fee2e2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #543717;
    transition: background 0.25s ease, border-color 0.25s ease;
  }
  .ws-pillar:hover .ws-pillar-icon-wrap {
    background: #543717;
    border-color: #543717;
    color: #fff;
  }
  .ws-pillar-icon-wrap svg { width: 1rem; height: 1rem; }
  .ws-pillar-title {
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #0f172a;
    margin: 0 0 0.2rem;
  }
  .ws-pillar-desc {
    font-family: 'Lato', sans-serif;
    font-size: 0.75rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }

  /* ── CTAs ── */
  .ws-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .ws-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: var(--btn-padding-desktop, 0.875rem 2rem);
    background: #543717;
    color: #fff;
    font-family: 'Lato', sans-serif;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 6px 20px rgba(var(--brand-rgb),0.30);
  }
  .ws-cta-link:hover {
    background: #3a2610;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(var(--brand-rgb),0.40);
  }
  .ws-cta-arrow {
    display: flex;
    align-items: center;
  }
  .ws-cta-arrow svg { width: 1rem; height: 1rem; }
  .ws-cta-secondary {
    font-family: 'Lato', sans-serif;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #543717;
    text-decoration: none;
    border-bottom: 1.5px solid #543717;
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .ws-cta-secondary:hover {
    color: #cb8f24;
    border-color: #cb8f24;
  }

  /* ── Scroll reveal animation ── */
  .ws-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ws-reveal.ws-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile responsive ── */
  @media (max-width: 900px) {
    .ws-main-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .ws-mission-banner {
      flex-direction: column;
      gap: 0.75rem;
    }
    .ws-mission-statement {
      font-size: 0.95rem;
    }
    .ws-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }

</style>
