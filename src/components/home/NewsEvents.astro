---
const currentYear = new Date().getFullYear();
const enrolmentYear = currentYear + 1;
const yearsOfExcellence = currentYear - 1967;

const stats = [
    { label: "Students Enrolled", value: "548", prefix: "", suffix: "" },
    { label: "Qualified Teachers", value: "16", prefix: "", suffix: "" },
    { label: "Pass Rate", value: "98", prefix: "", suffix: "%" },
    { label: "Years of Excellence", value: yearsOfExcellence.toString(), prefix: "", suffix: "" }
];

const highlights = [
    { title: "Upcoming Events", description: "Check our calendar for parent-teacher meetings, sports days, and cultural events.", btnText: "View Calendar", href: "/calendar" },
    { title: "Recent Achievements", description: "Our students excel in academics, sports, and cultural activities at district level.", btnText: "View Achievements", href: "/gallery/achievements" },
    { title: "Enrolment Open", description: `Applications for the ${enrolmentYear} academic year are now open. Limited spaces available.`, btnText: "Apply Now", href: "/enrolment" }
];

const news = [
    { date: "Dec 15, 2023", title: "Annual Prize Giving Ceremony", description: "Congratulations to all participants in our annual inter-house sports competition.", href: "/calendar" },
    { date: "Dec 10, 2023", title: "Holiday Break Schedule", description: "School will close on December 15th and reopen on January 8th, 2024.", href: "/calendar" },
    { date: "Dec 5, 2023", title: "New Library Resources", description: "Our library has been upgraded with new books and digital learning resources.", href: "/about" }
];

---
<section class="sh-news-section">

            <!-- Section label -->
            <div class="sh-section-label sh-reveal">
                <span class="sh-eyebrow">Stay Updated</span>
                <h2 class="sh-heading">News &amp; Announcements</h2>
                <div class="sh-rule"></div>
            </div>

            <!-- Accent banner -->
            <div class="sh-banner sh-reveal">
                <div class="sh-banner-left">
                    <svg class="w-5 h-5 text-gold-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                    <span>Latest News</span>
                </div>
                <p class="sh-banner-text">
                    From prize-giving ceremonies to holiday schedules and new resources — 
                    stay close to everything happening at Lotsha.
                </p>
            </div>

            <!-- News cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {news.map((item, i) => (
                    <div class={`group bg-white rounded-[2rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 p-8 flex flex-col relative overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.08)] hover:border-orange-200 sh-reveal`}>
                        <!-- Date & Icon Header -->
                        <div class="flex justify-between items-center mb-8 relative z-10">
                            <span class="text-[0.65rem] font-black tracking-widest uppercase text-slate-400 bg-slate-50 px-3 py-1 rounded-full">{item.date}</span>
                            <div class="w-10 h-10 flex items-center justify-center bg-orange-50 text-orange-400 rounded-xl transition-colors duration-500 group-hover:bg-orange-500 group-hover:text-white">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                                </svg>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="relative z-10 flex flex-col h-full">
                            <h3 class="text-xl font-bold text-slate-800 tracking-tight mb-4 group-hover:text-orange-600 transition-colors duration-300">{item.title}</h3>
                            <p class="text-sm font-lato text-slate-600 leading-relaxed mb-8 flex-grow">{item.description}</p>
                            
                            <a href={item.href} class="inline-flex items-center gap-2 text-xs font-black tracking-widest uppercase text-slate-400 group-hover:text-orange-500 transition-colors group/link">
                                Read Full Story
                                <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </div>
                ))}
            </div>
        </section>

