---
import { Image } from 'astro:assets';
const currentYear = new Date().getFullYear();
const enrolmentYear = currentYear + 1;
const yearsOfExcellence = currentYear - 1967;

const stats = [
    { label: "Students Enrolled", value: "548", prefix: "", suffix: "" },
    { label: "Qualified Teachers", value: "16", prefix: "", suffix: "" },
    { label: "Pass Rate", value: "98", prefix: "", suffix: "%" },
    { label: "Years of Excellence", value: yearsOfExcellence.toString(), prefix: "", suffix: "" }
];

const highlights = [
    { title: "Upcoming Events", description: "Check our calendar for parent-teacher meetings, sports days, and cultural events.", btnText: "View Calendar", href: "/calendar" },
    { title: "Recent Achievements", description: "Our students excel in academics, sports, and cultural activities at district level.", btnText: "View Achievements", href: "/gallery/achievements" },
    { title: "Enrolment Open", description: `Applications for the ${enrolmentYear} academic year are now open. Limited spaces available.`, btnText: "Apply Now", href: "/enrolment" }
];

const news = [
    { date: "Dec 15, 2023", title: "Annual Prize Giving Ceremony", description: "Congratulations to all participants in our annual inter-house sports competition.", href: "/calendar" },
    { date: "Dec 10, 2023", title: "Holiday Break Schedule", description: "School will close on December 15th and reopen on January 8th, 2024.", href: "/calendar" },
    { date: "Dec 5, 2023", title: "New Library Resources", description: "Our library has been upgraded with new books and digital learning resources.", href: "/about" }
];

---
<section id="hero" class="hero-section">

        <!-- ── Background Slider ── -->
        <div class="hero-bg-layer">
            <!-- Dark overlay for readability -->
            <div class="hero-overlay-dark"></div>
            <!-- Gradient vignette top/bottom -->
            <div class="hero-overlay-gradient"></div>

            <div class="hero-slider">
                <div class="slide active-slide">
                    <Image
                        class="hero-slide-img"
                        src="https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1440,h_800,c_fill/v1773823791/slide1_ydp9jd.avif"
                        alt="Welcome to Lotsha Primary"
                        width={1440}
                        height={800}
                        fetchpriority="high"
                        loading="eager"
                        decoding="sync"
                    />
                </div>
                <div class="slide">
                    <img class="hero-slide-img" decoding="async" alt="Lotsha Primary Students"
                        sizes="100vw"
                        data-srcset="
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_600,h_800,c_fill/v1773823793/slide2_yjoqb7.avif 600w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_824,h_824,c_fill/v1773823793/slide2_yjoqb7.avif 824w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1024,h_768,c_fill/v1773823793/slide2_yjoqb7.avif 1024w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1440,h_800,c_fill/v1773823793/slide2_yjoqb7.avif 1440w
                        "
                        data-src="https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1024,h_768,c_fill/v1773823793/slide2_yjoqb7.avif"
                    />
                </div>
                <div class="slide">
                    <img class="hero-slide-img" decoding="async" alt="Lotsha Primary School Facilities"
                        sizes="100vw"
                        data-srcset="
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_600,h_800,c_fill/v1773823793/slide3_liwnis.avif 600w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_824,h_824,c_fill/v1773823793/slide3_liwnis.avif 824w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1024,h_768,c_fill/v1773823793/slide3_liwnis.avif 1024w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1440,h_800,c_fill/v1773823793/slide3_liwnis.avif 1440w
                        "
                        data-src="https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1024,h_768,c_fill/v1773823793/slide3_liwnis.avif"
                    />
                </div>
                <div class="slide">
                    <img class="hero-slide-img" decoding="async" alt="Students in Classroom"
                        sizes="100vw"
                        data-srcset="
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_600,h_800,c_fill/v1773823794/slide4_uijohu.avif 600w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_824,h_824,c_fill/v1773823794/slide4_uijohu.avif 824w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1024,h_768,c_fill/v1773823794/slide4_uijohu.avif 1024w,
                            https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1440,h_800,c_fill/v1773823794/slide4_uijohu.avif 1440w
                        "
                        data-src="https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1024,h_768,c_fill/v1773823794/slide4_uijohu.avif"
                    />
                </div>
                <div class="slide">
                    <Image
                        class="hero-slide-img"
                        src="https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_40,w_1440,h_800,c_fill/v1773823795/slide5_nxrbzd.avif"
                        alt="School Extracurriculars"
                        width={1440}
                        height={800}
                        loading="eager"
                        decoding="async"
                    />
                </div>
            </div>
        </div>

        <!-- ── Main Hero Content ── -->
        <div class="hero-content-wrapper">
            <div class="hero-content">

                <!-- Heading: Welcome to (top-left) · TSHIKHUTHULA · Secondary School (bottom-right) -->
                <h1 class="hero-heading">
                    <span class="hero-reveal-1 ws-eyebrow">Welcome to</span>
                    <span class="hero-reveal-2 hero-school-name">LOTSHA</span>
                    <span class="hero-reveal-3 hero-secondary-label">Primary School</span>
                </h1>

                <!-- Decorative gold divider -->
                <div class="hero-divider"></div>

            </div>
        </div>

        <!-- ── Stats Bar (bottom strip) ── -->
        <div class="hero-stats-bar">
            {stats.map((stat, i) => (
                <div
                    class="hero-stat-card animate-fade-in"
                    style={`animation-delay: ${0.2 * i + 0.8}s; animation-fill-mode: forwards;`}
                >
                    <div class="hero-stat-icon">
                        {i === 0 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>}
                        {i === 1 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>}
                        {i === 2 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                        {i === 3 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.286-6.857L1 12l7.714-2.143L11 3z" /></svg>}
                    </div>
                    <div class="hero-stat-info">
                        <div class="hero-stat-number stat-number"
                             data-target={stat.value}
                             data-suffix={stat.suffix}>
                            {stat.prefix}0{stat.suffix}
                        </div>
                        <div class="hero-stat-label">{stat.label}</div>
                    </div>
                    <div class="hero-stat-divider"></div>
                </div>
            ))}
        </div>

        <!-- ── Tagline + Button pinned above chevron ── -->
        <div class="hero-bottom-block hero-subtitle-anim">
            <p class="hero-tagline">
                Nurturing Minds &nbsp;·&nbsp; Shaping Leaders &nbsp;·&nbsp; Building Excellence
            </p>
            <div class="hero-buttons-anim hero-ctas">
                <a href="/about" class="hero-btn hero-btn--primary">Discover More</a>
            </div>
        </div>

        <!-- ── Scroll indicator ── -->
        <a href="#welcome-header" class="hero-scroll-btn" aria-label="Scroll down">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 9l-7 7-7-7" />
            </svg>
        </a>

    </section>
        
<style>
/* ════ HERO – Structure ════ */
.hero-section {
    position: relative;
    width: 100%;
    height: 100svh; /* safe area aware */
    min-height: 600px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* ── Background layer ── */
  .hero-bg-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-overlay-dark {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    z-index: 2;
    pointer-events: none;
  }
  .hero-overlay-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15,23,42,0.75) 0%,
      transparent 35%,
      transparent 55%,
      rgba(15,23,42,0.80) 100%
    );
    z-index: 3;
    pointer-events: none;
  }
  .hero-slider {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero-slider .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 2s ease-in-out;
  }
  .hero-slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero-slider .slide.active-slide { opacity: 1; }

  .hero-content-wrapper {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: flex-start; 
    flex: 1;
    width: 100%;
    padding: 0 clamp(1.5rem, 6vw, 5rem);
    margin-top: -6vh; 
  }
  .hero-content {
    text-align: center;
    max-width: 64rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.25rem);
  }

  /* Heading block: width = width of the school name */
  .hero-heading {
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;  /* children fill the heading width */
    gap: 0;
    margin: 0;
  }
  /* "Welcome to" — thin, left edge, top */
  .hero-heading .ws-eyebrow {
    color: rgba(255,255,255,0.70);
    text-shadow: 0 2px 8px rgba(0,0,0,0.35);
    margin-bottom: 0.25rem;
    align-self: flex-start;
  }
  /* Main school name */
  .hero-school-name {
    display: block;
    font-family: 'Quicksand', sans-serif;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0.12em;
    color: #cb8f24;
    font-size: clamp(2.2rem, 6.5vw, 5rem);
    text-shadow: 0 0 60px rgba(203,143,36,0.20), 0 4px 24px rgba(0,0,0,0.50);
    white-space: nowrap;
  }
  /* "Secondary School" — thin, right edge, bottom */
  .hero-secondary-label {
    display: block;
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: clamp(0.65rem, 1.8vw, 1rem);
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.70);
    text-shadow: 0 2px 8px rgba(0,0,0,0.35);
    text-align: right;
    margin-top: 0.25rem;
    align-self: flex-end;
  }

  /* ── Gold divider ── */
  .hero-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, #cb8f24, transparent);
    width: clamp(100px, 25vw, 180px);
    transform-origin: center;
    opacity: 0;
    transform: scaleX(0);
    animation: heroDividerExpand 0.8s cubic-bezier(0.22, 1, 0.36, 1) 1.1s forwards;
  }

  /* ── Tagline ── */
  .hero-tagline {
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: clamp(0.6rem, 1.8vw, 1rem);
    text-align: center;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    white-space: nowrap; /* Ensure tagline stays on one line */
    line-height: 1.8;
    max-width: 38rem;
  }

  /* ── CTA Buttons ── */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2.2rem;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: clamp(0.65rem, 1.4vw, 0.8rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
    border: none;
    outline: none;
  }
  .hero-btn:hover { transform: translateY(-3px); }
  .hero-btn--primary {
    background: #543717;
    color: #fff;
    box-shadow: 0 8px 32px rgba(var(--brand-rgb),0.35);
  }
  .hero-btn--primary:hover {
    background: #3a2610;
    box-shadow: 0 12px 40px rgba(var(--brand-rgb),0.5);
  }
  .hero-btn--secondary {
    background: rgba(255,255,255,0.10);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.30);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .hero-btn--secondary:hover {
    background: rgba(255,255,255,0.20);
    border-color: rgba(255,255,255,0.55);
  }

  
/* ════ STATS BAR – bottom strip ════ */
.hero-stats-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: rgba(6, 11, 20, 0.45);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .hero-stat-card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 1.25rem 1rem;
    position: relative;
    opacity: 0;
    transition: background 0.3s ease;
  }
  .hero-stat-card:hover { background: rgba(255,255,255,0.05); }

  .hero-stat-icon {
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(var(--brand-rgb), 0.15);
    border: 1px solid rgba(var(--brand-rgb), 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #543717;
    flex-shrink: 0;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }
  .hero-stat-card:hover .hero-stat-icon {
    transform: scale(1.1) rotate(-5deg);
    border-color: #543717;
    background: rgba(var(--brand-rgb), 0.25);
    color: #fff;
  }
  .hero-stat-icon svg { width: 1.1rem; height: 1.1rem; }

  .hero-stat-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .hero-stat-number {
    font-family: 'Bodoni Moda', serif;
    font-weight: 200;
    font-size: clamp(1.2rem, 2.5vw, 1.65rem);
    color: #deb056;
    line-height: 1;
    text-shadow: 0 0 16px rgba(253,230,138,0.35);
  }
  .hero-stat-label {
    font-family: 'Lato', sans-serif;
    font-weight: 800;
    font-size: 0.52rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.60);
    line-height: 1.2;
    white-space: nowrap;
  }

  .hero-stat-divider {
    position: absolute;
    right: 0;
    top: 25%;
    bottom: 25%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.1), transparent);
  }
  .hero-stat-card:last-child .hero-stat-divider { display: none; }

  /* ── Discover More button anchored above chevron ── */
  .hero-bottom-cta {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 20;
    bottom: calc(clamp(3rem, 7vw, 4rem) + 0.25rem + 2.75rem + 0.6rem);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ── Tagline + Button block pinned above chevron ── */
  .hero-bottom-block {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 20;
    /* chevron bottom (stats bar height + 1rem) + chevron height (2.75rem) + 1rem gap */
    bottom: calc(var(--stats-bar-height, 80px) + 1rem + 2.75rem + 1rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.5rem);
    padding: 0 1rem;
    transition: bottom 0.2s ease;
  }

  /* ── Scroll indicator ── */
  .hero-scroll-btn {
    position: absolute;
    /* Sits 1rem above the stats bar — JS sets --stats-bar-height */
    bottom: calc(var(--stats-bar-height, 80px) + 1rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    border: 1.5px solid rgba(255,255,255,0.28);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    animation: scrollBounce 2s ease-in-out 2.2s infinite;
    transition: background 0.2s ease, bottom 0.2s ease;
  }
  .hero-scroll-btn:hover { background: rgba(255,255,255,0.20); }
  .hero-scroll-btn svg { width: 1.1rem; height: 1.1rem; }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  
/* ════ Entrance keyframes ════ */
@keyframes heroRevealUp {
    0%   { opacity: 0; transform: translateY(60%) skewY(4deg); }
    100% { opacity: 1; transform: translateY(0) skewY(0deg); }
  }
  @keyframes heroDividerExpand {
    0%   { transform: scaleX(0); opacity: 0; }
    100% { transform: scaleX(1); opacity: 1; }
  }
  @keyframes heroFadeUp {
    0%   { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .hero-reveal-1 {
    opacity: 0;
    animation: heroRevealUp 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }
  .hero-reveal-2 {
    opacity: 0;
    animation: heroRevealUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
  }
  .hero-reveal-3 {
    opacity: 0;
    animation: heroRevealUp 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.85s forwards;
  }
  .hero-subtitle-anim {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1.3s forwards;
  }
  .hero-buttons-anim {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1.55s forwards;
  }

  
/* ════ MOBILE RESPONSIVE ════ */
/* Tablet: keep 4 cols but smaller */
  /* Tablet: keep 4 cols but smaller */
  @media (max-width: 768px) {
    .hero-stats-bar {
      grid-template-columns: repeat(4, 1fr);
    }
    .hero-stat-card {
      padding: 0.85rem 0.25rem;
    }
    .hero-content-wrapper {
      justify-content: flex-end; 
      padding-bottom: 25vh;
      margin-top: 0;
      padding-top: 0;
      padding-right: clamp(1.25rem, 5vw, 3rem);
      padding-left: 1.25rem;
    }
    .hero-content {
      padding-top: 0;
    }
  }

  /* Mobile: 2x2 grid for stats and push the tagline UP so they don't overlap */
  @media (max-width: 640px) {
    .hero-stats-bar {
      grid-template-columns: repeat(2, 1fr);
      border-top: none; 
    }
    .hero-stat-card {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 1rem 0.5rem;
    }
    .hero-bottom-block {
      gap: 0.75rem; 
    }
    .hero-tagline {
      white-space: normal; 
      max-width: 90%;
      line-height: 1.5;
    }
    .hero-school-name {
      font-size: 1.76rem;
    }
    .hero-heading .ws-eyebrow {
      font-size: 10.4px;
    }
  }

  /* Small mobile: 2×2 grid */
  @media (max-width: 480px) {
    .hero-stats-bar {
      grid-template-columns: repeat(2, 1fr);
    }
    .hero-stat-card:nth-child(2) { border-right: none; }
    .hero-stat-card:nth-child(3) {
      border-right: 1px solid rgba(255,255,255,0.08);
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .hero-stat-card:nth-child(4) {
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .hero-content-wrapper {
      padding-right: 1.25rem;
      padding-left: 1.25rem;
    }
    .hero-ctas {
      flex-direction: column;
      width: 100%;
      max-width: 14.4rem;
    }
    .hero-btn {
      width: 100%;
      justify-content: center;
    }
  }

  
</style>
