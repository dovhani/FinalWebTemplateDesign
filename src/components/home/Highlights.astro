---
const currentYear = new Date().getFullYear();
const enrolmentYear = currentYear + 1;
const yearsOfExcellence = currentYear - 1967;

const highlights = [
    { title: "Upcoming Events", description: "Check our calendar for parent-teacher meetings, sports days, and cultural events.", btnText: "View Calendar", href: "/calendar" },
    { title: "Recent Achievements", description: "Our students excel in academics, sports, and cultural activities at district level.", btnText: "View Achievements", href: "/gallery/achievements" },
    { title: "Enrolment Open", description: `Applications for the ${enrolmentYear} academic year are now open. Limited spaces available.`, btnText: "Apply Now", href: "/enrolment" }
];
---
<div class="sh-section">

            <!-- Section label (same pattern as welcome) -->
            <div class="sh-section-label sh-reveal">
                <span class="sh-eyebrow">In Pursuit of Glory</span>
                <h2 class="sh-heading">School Highlights</h2>
                <div class="sh-rule"></div>
            </div>

            <!-- Accent banner -->
            <div class="sh-banner sh-reveal">
                <div class="sh-banner-left">
                    <svg class="w-5 h-5 text-gold-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                    </svg>
                    <span>Highlights</span>
                </div>
                <p class="sh-banner-text">
                    Celebrating the milestones, events, and achievements that define the Lotsha spirit — 
                    a community united by excellence and powered by purpose.
                </p>
            </div>

            <!-- Cards grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {highlights.map((item, i) => (
                    <div class={`group bg-white rounded-[2rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 p-10 flex flex-col relative overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.08)] hover:border-orange-200 sh-reveal`}>
                        <!-- Number Accent -->
                        <div class="absolute -top-6 -right-6 w-24 h-24 bg-orange-50 rounded-full flex items-center justify-center text-orange-200 font-black text-4xl pt-4 pr-4 transition-colors duration-500 group-hover:bg-orange-100 group-hover:text-orange-300">
                            0{i + 1}
                        </div>

                        <!-- Icon Container -->
                        <div class="w-16 h-16 flex items-center justify-center bg-slate-900 text-gold-400 rounded-2xl mb-8 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-6 relative z-10">
                            {i === 0 && (
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            )}
                            {i === 1 && (
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            )}
                            {i === 2 && (
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                </svg>
                            )}
                        </div>

                        <!-- Content -->
                        <div class="relative z-10 flex flex-col h-full">
                            <h3 class="text-xl font-bold text-slate-800 tracking-tight mb-4">{item.title}</h3>
                            <p class="text-sm font-lato text-slate-600 leading-relaxed mb-8 flex-grow">{item.description}</p>
                            
                            <a href={item.href} class="inline-flex items-center gap-2 text-xs font-black tracking-widest uppercase text-orange-500 hover:text-orange-600 transition-colors group/link">
                                {item.btnText}
                                <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        

