---
import Layout from '../../layouts/Layout.astro';
import SecondaryNav from '../../components/SecondaryNav.astro';
import SubNav from '../../components/SubNav.astro';
import '../../styles/our-school.css';

const schoolSubNavItems = [
    { title: 'Staff Directory', href: '/our-school/staff' },
    { title: 'School Governing Body', href: '/our-school/sgb' },
    { title: 'Food Handlers', href: '/our-school/food-handlers' },
    { title: 'Ground Workers', href: '/our-school/ground-workers' },
    { title: 'Security', href: '/our-school/security' }
];

const staffMembers = [
    {
        name: "Jane Smith",
        title: "Principal",
        position: "Principal & Academic Head",
        qualifications: "M.Ed Educational Leadership, B.Ed, 15 years experience",
        email: "principal@learningacademy.edu",
        phone: "Ext. 101",
        office: "Administration Building, Room 101"
    },
    {
        name: "Robert Davis",
        title: "Deputy Principal",
        position: "Deputy Principal & Discipline Head",
        qualifications: "B.Ed Honours, 12 years experience",
        email: "deputy@learningacademy.edu",
        phone: "Ext. 102",
        office: "Administration Building, Room 102"
    },
    {
        name: "Mary Wilson",
        title: "Head of Academics",
        position: "Head of Academics & Curriculum",
        qualifications: "M.Sc Mathematics, B.Ed, 10 years experience",
        email: "academics@learningacademy.edu",
        phone: "Ext. 103",
        office: "Academic Block, Room 201"
    }
];
---

<Layout title="Staff Directory - Tshikhuthula Secondary School" currentPage="our-school" noNavbarPadding={true} showMainNav={true}>
    <SecondaryNav currentPage="our-school" />
    <!-- ── Header ── -->
    <header class="our-school-header ws-reveal">
        <div class="our-school-header-bg"></div>
        <div class="our-school-header-content">
            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full border border-gold-500/30 bg-gold-500/10 backdrop-blur-md mb-6">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-gold-400">Directory</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-heading text-white font-display drop-shadow-lg tracking-tight mb-6">
                Teaching <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-gold-600">Staff</span>
            </h1>
            <p class="text-slate-300 max-w-3xl mx-auto text-lg leading-relaxed font-lato">
                Meet our dedicated team of educators and support staff.
            </p>
        </div>
    </header>
    
    <SubNav items={schoolSubNavItems} activeHref="/our-school/staff" />
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 space-y-20">
        <section>
            <h2 class="text-3xl font-heading text-slate-900 mb-12 text-center">Leadership Team</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {staffMembers.map((staff, i) => (
                    <div class="group bg-white border border-slate-100 shadow-sm hover:shadow-[0_20px_40px_-15px_rgba(128,0,0,0.1)] hover:border-maroon-800/20 transition-all overflow-hidden animate-fade-in opacity-0" style={`animation-delay: ${0.1 * i}s; animation-fill-mode: forwards;`}>
                        <div class="h-1 bg-gradient-to-r from-maroon-800 to-gold-500 transition-all duration-500 group-hover:h-2"></div>
                        <div class="p-8">
                            <div class="text-[9px] font-black uppercase tracking-[0.2em] text-gold-600 mb-2">{staff.title}</div>
                            <h3 class="text-2xl font-bold text-slate-900 font-display mb-4 group-hover:text-maroon-800 transition-colors">{staff.name}</h3>
                            
                            <div class="space-y-4">
                                <div>
                                    <div class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Position</div>
                                    <p class="text-sm font-bold text-slate-700">{staff.position}</p>
                                </div>
                                <div>
                                    <div class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Qualifications</div>
                                    <p class="text-xs text-slate-500 font-medium leading-relaxed">{staff.qualifications}</p>
                                </div>
                                <div class="pt-4 border-t border-slate-50 space-y-2">
                                    <div class="flex items-center gap-2 text-xs text-slate-500">
                                        <span>📧</span> {staff.email}
                                    </div>
                                    <div class="flex items-center gap-2 text-xs text-slate-500">
                                        <span>📞</span> {staff.phone}
                                    </div>
                                    <div class="flex items-center gap-2 text-xs text-slate-500">
                                        <span>📍</span> {staff.office}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>
        
        <section class="glass p-12 text-center">
            <h3 class="text-2xl font-heading text-slate-900 mb-6">Need Assistance?</h3>
            <p class="text-slate-500 mb-10 max-w-xl mx-auto font-medium">If you can't find the staff member you're looking for, please visit our contact page or school office.</p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="/" class="px-8 py-3 bg-white border border-slate-200 text-slate-900 font-bold hover:bg-slate-50 transition-all shadow-sm">Home</a>
                <a href="/enrolment" class="px-8 py-3 bg-slate-900 text-white font-bold hover:bg-maroon-800 transition-all shadow-xl">Enrol Now</a>
            </div>
        </section>
    </div>
</Layout>
