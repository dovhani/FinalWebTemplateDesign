---

<Layout title="Staff Directory - Lotsha Primary School"
    description="Meet the dedicated teaching staff at Lotsha Primary School - qualified educators committed to nurturing each learner's potential." currentPage="our-school" noNavbarPadding={true} showMainNav={true}>
    <SecondaryNav currentPage="our-school" />
    <!-- ── Header ── -->
    <header class="our-school-header ws-reveal">
        <div class="our-school-header-bg">
             <img class="absolute inset-0 w-full h-full object-cover opacity-35" fetchpriority="high" decoding="sync" alt="School presentation" src="https://res.cloudinary.com/djpfl2uwe/image/upload/f_avif,q_auto,w_1440,c_fill/v1773823795/slide5_nxrbzd.avif" />
        </div>
        <div class="our-school-header-content">
            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full border border-gold-500/30 bg-gold-500/10 backdrop-blur-md mb-6">
                <span class="page-eyebrow">Directory</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-heading text-white font-display drop-shadow-lg tracking-tight mb-6">
                Teaching <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-gold-600">Staff</span>
            </h1>
            <p class="page-tagline">
                Meet our dedicated team of educators and support staff.
            </p>
        </div>
    </header>
    
    <SubNav items={schoolSubNavItems} activeHref="/our-school/staff" />
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 space-y-20">
        <section>
            <h2 class="text-3xl font-heading text-slate-900 mb-12 text-center">Meet Our Staff</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-40 pt-28">
                {staffMembers.map((staff, i) => (
                    <div class="animate-fade-in opacity-0" style={`animation-delay: ${0.05 * i}s; animation-fill-mode: forwards;`}>
                        <div
                            class="staff-card bg-white px-8 pt-12 pb-10 shadow-xl shadow-black/[0.05] rounded-3xl text-center flex flex-col justify-between h-full max-w-md mx-auto transition-colors cursor-pointer group hover:shadow-2xl hover:shadow-black/[0.1] border border-slate-100"
                            data-name={staff.name}
                            data-title={staff.title}
                            data-position={staff.position}
                            data-quals={staff.qualifications}
                            data-email={staff.email}
                            data-phone={staff.phone}
                            data-office={staff.office}
                            data-img={staff.image}
                        >
                            <!-- avatar -->
                            <div class="select-none flex justify-center">
                                <img
                                    src={staff.image}
                                    class="shadow-2xl shadow-black/[0.1] rounded-3xl h-60 w-60 object-cover object-top mx-auto -mt-36 transform-gpu transition-transform duration-500 group-hover:scale-110 bg-slate-100 border-[6px] border-white"
                                    style="user-select: none"
                                    alt={staff.name}
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>

                            <!-- name content -->
                            <div class="flex-1 flex flex-col justify-center mt-8">
                                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-gold-600 mb-2">{staff.title}</span>
                                <h1 class="text-2xl font-bold text-slate-800 font-display line-clamp-1 group-hover:text-maroon-800 transition-colors">
                                    {staff.name}
                                </h1>
                                <p class="mt-3 text-slate-500 font-medium text-sm">
                                    {staff.position}
                                </p>
                            </div>

                            <!-- button -->
                            <div class="mt-8 flex justify-center">
                                <button
                                    class="bg-maroon-800 font-bold text-white px-6 py-2.5 rounded-xl flex items-center justify-center space-x-2 transform-gpu transition-all duration-200 hover:bg-maroon-900 group-active:scale-95 w-full sm:w-auto min-w-[160px]"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                                    <span class="text-sm">Profile</span>
                                </button>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>
        
    <!-- Staff Modal -->
    <div id="staffModal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 md:p-8 opacity-0 pointer-events-none transition-all duration-500">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-xl transition-opacity duration-500" id="modalBackdrop"></div>
        
        <!-- Premium Modal Content Container -->
        <div 
            class="w-full md:w-[75vw] lg:w-[65vw] max-w-5xl relative z-10 flex flex-col md:flex-row transform scale-95 opacity-0 transition-all duration-500 ease-out bg-white rounded-3xl overflow-hidden shadow-[0_20px_60px_-15px_rgba(0,0,0,0.3)]" 
            id="modalContent"
        >
            <!-- Close button -->
            <button id="closeModalBtn" class="absolute top-4 right-4 md:top-6 md:right-6 z-30 w-10 h-10 bg-black/5 hover:bg-maroon-800 text-slate-500 hover:text-white rounded-full flex items-center justify-center transition-all duration-300 cursor-pointer backdrop-blur-md" aria-label="Close modal">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            
            <!-- Left Side: Image Profile -->
            <div class="w-full md:w-2/5 h-64 md:h-auto relative shrink-0 overflow-hidden bg-slate-100 border-r border-slate-100">
                <img 
                    id="modalImg" 
                    src="" 
                    alt="Staff Member" 
                    class="absolute inset-0 w-full h-full object-cover object-top" 
                />
            </div>
            
            <!-- Right Side: Content Details -->
            <div class="w-full md:w-3/5 p-8 md:p-12 lg:p-14 flex flex-col justify-center bg-white relative">
                <!-- Watermark -->
                <div class="absolute top-10 right-10 text-[120px] font-black text-slate-50 opacity-50 select-none pointer-events-none leading-none z-0" aria-hidden="true" style="font-family: serif;">Lotsha</div>

                <div class="relative z-10">
                    <span id="modalTitle" class="inline-flex px-3 py-1 rounded-full bg-gold-50 text-gold-700 text-[10px] font-black uppercase tracking-[0.2em] mb-4 border border-gold-200/50"></span>
                    <h3 id="modalName" class="text-3xl md:text-5xl font-extrabold text-slate-900 font-display mb-2 leading-tight"></h3>
                    <p id="modalPosition" class="text-lg md:text-xl font-medium text-maroon-800/80 mb-8"></p>
                    
                    <div class="space-y-8 mt-2">
                        <!-- Qualifications -->
                        <div class="bg-slate-50/50 rounded-2xl p-5 border border-slate-100">
                            <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                                Academic Background
                            </h4>
                            <p id="modalQuals" class="text-sm md:text-base text-slate-600 font-medium leading-relaxed"></p>
                        </div>
                        
                        <!-- Contact Grid -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <!-- Email -->
                            <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors group">
                                <div class="w-10 h-10 rounded-full bg-maroon-50 flex items-center justify-center shrink-0 text-maroon-800 group-hover:scale-110 transition-transform">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                </div> 
                                <div>
                                    <div class="text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-0.5">Contact Email</div>
                                    <a id="modalEmail" href="#" class="text-sm font-semibold text-slate-700 hover:text-maroon-800 transition-colors line-clamp-1"></a>
                                </div>
                            </div>
                            
                            <!-- Phone -->
                            <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors group">
                                <div class="w-10 h-10 rounded-full bg-gold-50 flex items-center justify-center shrink-0 text-gold-600 group-hover:scale-110 transition-transform">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                </div> 
                                <div>
                                    <div class="text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-0.5">Direct Line</div>
                                    <a id="modalPhone" href="#" class="text-sm font-semibold text-slate-700 hover:text-gold-600 transition-colors line-clamp-1"></a>
                                </div>
                            </div>

                            <!-- Office -->
                            <div class="flex items-start gap-4 p-4 rounded-xl sm:col-span-2 hover:bg-slate-50 transition-colors group">
                                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center shrink-0 text-slate-500 group-hover:scale-110 transition-transform">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                                </div> 
                                <div>
                                    <div class="text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-0.5">Office Location</div>
                                    <span id="modalOffice" class="text-sm font-semibold text-slate-700"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    function openStaffModal(card) {
        const modal = document.getElementById('staffModal');
        const modalContent = document.getElementById('modalContent');
        if (!modal || !modalContent) return;
        
        // Populate
        document.getElementById('modalName').textContent = card.dataset.name || '';
        document.getElementById('modalTitle').textContent = card.dataset.title || '';
        document.getElementById('modalPosition').textContent = card.dataset.position || '';
        document.getElementById('modalQuals').textContent = card.dataset.quals || '';
        document.getElementById('modalEmail').textContent = card.dataset.email || '';
        document.getElementById('modalPhone').textContent = card.dataset.phone || '';
        document.getElementById('modalOffice').textContent = card.dataset.office || '';
        
        const img = document.getElementById('modalImg');
        if (img) {
            img.src = card.dataset.img || '';
            img.alt = card.dataset.name || '';
        }
        
        // Show
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
        document.body.style.overflow = 'hidden';
    }
    
    function closeStaffModal() {
        const modal = document.getElementById('staffModal');
        const modalContent = document.getElementById('modalContent');
        if (!modal || !modalContent) return;
        
        // Hide
        modal.classList.add('opacity-0', 'pointer-events-none');
        modalContent.classList.remove('scale-100', 'opacity-100');
        modalContent.classList.add('scale-95', 'opacity-0');
        document.body.style.overflow = '';
    }
    
    function initStaffCards() {
        const cards = document.querySelectorAll('.staff-card');
        cards.forEach(card => {
            // Remove existing listeners to prevent duplicates if init is run multiple times
            const newCard = card.cloneNode(true);
            if(card.parentNode) {
                card.parentNode.replaceChild(newCard, card);
                newCard.addEventListener('click', () => openStaffModal(newCard));
            }
        });
        
        const closeBtn = document.getElementById('closeModalBtn');
        const backdrop = document.getElementById('modalBackdrop');
        
        if (closeBtn) closeBtn.addEventListener('click', closeStaffModal);
        if (backdrop) backdrop.addEventListener('click', closeStaffModal);
        
        // Close on escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeStaffModal();
        });
    }
    
    // Initialize
    initStaffCards();
    document.addEventListener('astro:after-swap', initStaffCards);
</script>
