---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import SecondaryNav from '../components/SecondaryNav.astro';
import '../styles/student-life.css';

const sports = [
    {
        title: "Soccer",
        image: "/assets/images/student_life/soccer.jpeg",
        desc: "Our flagship sport with highly competitive boys' and girls' teams participating in regional leagues and tournaments.",
        tags: ["Boys & Girls", "League", "Term 2 & 3"]
    },
    {
        title: "Netball",
        image: "/assets/images/student_life/netball.jpg",
        desc: "A cornerstone of women's sports at our school, known for dominating district championships and developing talent.",
        tags: ["Girls", "League", "Term 2 & 3"]
    },
    {
        title: "Athletics",
        image: "/assets/images/student_life/athlets.webp",
        desc: "Track and field stars are born here. We host an annual inter-house athletics day that is a highlight of the school calendar.",
        tags: ["Track & Field", "Inter-house", "Term 1"]
    },
    {
        title: "Volleyball",
        image: "/assets/images/student_life/volley.jpg",
        desc: "A fast-growing sport at Lotsha with professional courts and dedicated coaching staffs.",
        tags: ["Boys & Girls", "Social & League"]
    }
];

const culture = [
    {
        title: "Traditional Dance",
        image: "/assets/images/student_life/dance.jpeg",
        desc: "Celebrating our heritage through Tshivenda, Xitsonga, and other traditional dance groups performing at major events.",
        tags: ["Heritage", "Performance"]
    },
    {
        title: "School Choir",
        image: "/assets/images/student_life/choir.jpg",
        desc: "Our award-winning choral group performs classical, contemporary, and traditional African musical pieces.",
        tags: ["Vocal", "Competitions"]
    },
    {
        title: "Debating Society",
        image: "/assets/images/student_life/debate.jpeg",
        desc: "Developing eloquent speakers and critical thinkers. Our teams compete in the provincial debating leagues.",
        tags: ["Public Speaking", "Academic"]
    }
];

const leadership = [
    {
        title: "Learner Representative Council (LRC)",
        image: "/assets/images/student_life/lrc.jpg",
        desc: "The student voice. Democratically elected leaders who work with management to improve student welfare.",
        tags: ["Governance", "Elected"]
    },
    {
        title: "Peer Educators",
        image: "/assets/images/student_life/peer.jpeg",
        desc: "Trained students who provide guidance, support, and necessary information regarding health and social issues to their peers.",
        tags: ["Counseling", "Support"]
    },
    {
        title: "Environmental Club",
        image: "/assets/images/student_life/environment.jpg",
        desc: "Championing sustainability, recycling initiatives, and the maintenance of our campus gardens.",
        tags: ["Green Campus", "Service"]
    }
];
---

<Layout title="Student Life - Lotsha Primary School"
    description="Explore student life at Lotsha Primary School - sports, arts, clubs, cultural activities, and all the ways learners grow beyond the classroom." currentPage="student-life" noNavbarPadding={true} showMainNav={true}>
    
    <!-- ── Header ── -->
    <header class="life-header ws-reveal">
        <div class="life-header-bg"></div>
        <div class="life-header-content">
            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full border border-gold-500/30 bg-gold-500/10 backdrop-blur-md mb-6">
                <span class="page-eyebrow">Beyond the Classroom</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-heading text-white font-display drop-shadow-lg tracking-tight mb-6">
                Student <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-gold-600">Life</span>
            </h1>
            <p class="life-header-tagline">
                At Lotsha Primary School, education extends far beyond academics. We believe in holistic development, fostering talents in sports, arts, and leadership.
            </p>
        </div>
    </header>

    <!-- ── Sports Section ── -->
    <section class="activity-section">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label mb-10 ws-reveal">
                <span class="ab-label-eyebrow">Athletics & Teams</span>
                <h2 class="ab-label-heading">Sports & Recreation</h2>
                <div class="ab-label-rule"></div>
            </div>

            <div class="activity-grid">
                {sports.map((sport, i) => (
                    <div class={`activity-card ws-reveal delay-${(i % 4) + 1}`}>
                        <img src={sport.image} alt={sport.title} loading="lazy" decoding="async" />
                        <div class="activity-overlay">
                            <h3 class="activity-title">{sport.title}</h3>
                            <p class="activity-desc">{sport.desc}</p>
                            <div class="activity-tags">
                                {sport.tags.map(tag => <span class="activity-tag">{tag}</span>)}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── Arts & Culture ── -->
    <section class="activity-section">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label items-end text-right mb-10 ws-reveal">
                <span class="ab-label-eyebrow">Creative Expression</span>
                <h2 class="ab-label-heading">Arts & Culture</h2>
                <div class="ab-label-rule ml-auto"></div>
            </div>

            <div class="activity-grid" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));">
                {culture.map((item, i) => (
                    <div class={`activity-card ws-reveal delay-${(i % 4) + 1}`}>
                        <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                        <div class="activity-overlay">
                            <h3 class="activity-title">{item.title}</h3>
                            <p class="activity-desc">{item.desc}</p>
                            <div class="activity-tags">
                                {item.tags.map(tag => <span class="activity-tag">{tag}</span>)}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── Leadership & Clubs ── -->
    <section class="activity-section">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label mb-10 ws-reveal">
                <span class="ab-label-eyebrow">Growth & Service</span>
                <h2 class="ab-label-heading">Leadership & Clubs</h2>
                <div class="ab-label-rule"></div>
            </div>

            <div class="activity-grid">
                {leadership.map((club, i) => (
                    <div class={`activity-card ws-reveal delay-${(i % 4) + 1}`}>
                        <img src={club.image} alt={club.title} loading="lazy" decoding="async" />
                        <div class="activity-overlay">
                            <h3 class="activity-title">{club.title}</h3>
                            <p class="activity-desc">{club.desc}</p>
                            <div class="activity-tags">
                                {club.tags.map(tag => <span class="activity-tag">{tag}</span>)}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
            
            <!-- Call to action block -->
            <div class="mt-20 p-10 md:p-16 bg-maroon-900 rounded-[2rem] text-center ws-reveal text-white shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-r from-maroon-900 via-maroon-800 to-maroon-900"></div>
                <div class="relative z-10">
                    <h3 class="text-3xl font-heading mb-4 text-gold-400">Join a Society Today</h3>
                    <p class="max-w-2xl mx-auto font-lato text-slate-300 leading-relaxed mb-8">
                        Every learner is encouraged to participate in at least one summer and one winter extracurricular activity. Speak to the sports or culture coordinator for registration forms.
                    </p>
                    <a href="/contact" class="inline-block px-8 py-3 bg-white text-maroon-900 font-bold uppercase tracking-[0.2em] text-xs rounded-lg hover:bg-gold-400 transition-colors shadow-lg">Contact Coordinators</a>
                </div>
            </div>
        </div>
    </section>

</Layout>


<ScrollReveal />

