---
import Layout from '../layouts/Layout.astro';
import SecondaryNav from '../components/SecondaryNav.astro';
import '../styles/wall-of-fame.css';

const topAchievers = [
    {
        name: "Mukovhe Mudau",
        year: "Class of 2023",
        image: "/assets/images/gallery/grid6.jpg",
        badge: "Top Matriculant",
        achievements: "Achieved 7 Distinctions including 98% in Mathematics and 95% in Physical Sciences.",
        stats: [
            { label: "Distinctions", value: "7" },
            { label: "Avg", value: "92%" }
        ]
    },
    {
        name: "Tshedza Ndou",
        year: "Class of 2022",
        image: "/assets/images/gallery/grid5.jpg",
        badge: "Provincial Top 10",
        achievements: "Ranked 3rd in the Limpopo Province for the National Senior Certificate Examinations.",
        stats: [
            { label: "Distinctions", value: "7" },
            { label: "Avg", value: "94%" }
        ]
    },
    {
        name: "Rofhiwa Mulaudzi",
        year: "Class of 2021",
        image: "/assets/images/gallery/grid4.jpg",
        badge: "Dux Scholar",
        achievements: "Awarded a full scholarship to study Medicine at the University of Cape Town.",
        stats: [
            { label: "Distinctions", value: "6" },
            { label: "Avg", value: "89%" }
        ]
    }
];

const notableAlumni = [
    {
        name: "Dr. Nndwakhulu Netshisaulu",
        year: "Class of 2005",
        image: "/assets/images/gallery/grid2.jpg",
        role: "Cardiothoracic Surgeon",
        bio: "Leading surgeon at a major national hospital, recognized for pioneering research in minimally invasive heart surgery."
    },
    {
        name: "Grace Ramabulana",
        year: "Class of 2010",
        image: "/assets/images/gallery/grid1.jpg",
        role: "Tech Entrepreneur",
        bio: "Founder of a highly successful ed-tech startup providing digital learning resources to rural communities."
    },
    {
        name: "David Mphaphuli",
        year: "Class of 2012",
        image: "/assets/images/gallery/grid3.jpg",
        role: "Chartered Accountant",
        bio: "Director at a top 4 international accounting firm, and active mentor to our current Commerce students."
    }
];
---

<Layout title="Wall of Fame - Tshikhuthula Secondary School" currentPage="wall-of-fame" noNavbarPadding={true} showMainNav={true}>
    
    <!-- ── Header ── -->
    <header class="fame-header ws-reveal">
        <div class="fame-header-bg"></div>
        <div class="fame-header-content">
            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full border border-gold-500/30 bg-gold-500/10 backdrop-blur-md mb-6">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-gold-400">Celebrating Excellence</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-heading text-white font-display drop-shadow-lg tracking-tight mb-6">
                Wall of <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-gold-600">Fame</span>
            </h1>
            <p class="text-slate-300 max-w-2xl mx-auto font-lato text-lg leading-relaxed">
                Honoring the extraordinary achievements of our learners. From academic brilliance to professional success, we celebrate those who embody the spirit of Tshikhuthula.
            </p>
        </div>
    </header>

    <!-- ── Recent Top Achievers ── -->
    <section class="fame-section bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label mb-10 ws-reveal text-center items-center">
                <span class="ab-label-eyebrow">Academic Brilliance</span>
                <h2 class="ab-label-heading">Recent Top Achievers</h2>
                <div class="ab-label-rule mx-auto mb-8"></div>
                
                <!-- Filter Buttons -->
                <div class="flex flex-wrap justify-center gap-2 mb-8" id="achiever-filters">
                    <button class="filter-btn active text-[10px] font-black uppercase tracking-widest px-6 py-3 transition-all duration-300 bg-primary-700 text-white shadow-lg border border-primary-600 rounded-full" data-filter="all">All</button>
                    <button class="filter-btn text-[10px] font-black uppercase tracking-widest px-6 py-3 transition-all duration-300 bg-slate-100 text-slate-500 hover:bg-slate-200 hover:text-slate-900 border border-slate-200 rounded-full" data-filter="Class of 2023">2023</button>
                    <button class="filter-btn text-[10px] font-black uppercase tracking-widest px-6 py-3 transition-all duration-300 bg-slate-100 text-slate-500 hover:bg-slate-200 hover:text-slate-900 border border-slate-200 rounded-full" data-filter="Class of 2022">2022</button>
                    <button class="filter-btn text-[10px] font-black uppercase tracking-widest px-6 py-3 transition-all duration-300 bg-slate-100 text-slate-500 hover:bg-slate-200 hover:text-slate-900 border border-slate-200 rounded-full" data-filter="Class of 2021">2021</button>
                </div>
            </div>

            <div class="fame-grid mt-12" id="achievers-grid">
                {topAchievers.map((achiever, i) => (
                    <div class={`achiever-card ws-reveal delay-${i+1}`} data-year={achiever.year}>
                        <div class="achiever-badge">{achiever.badge}</div>
                        <div class="achiever-image-container">
                            <img src={achiever.image} alt={achiever.name} class="achiever-image" />
                        </div>
                        <div class="achiever-content">
                            <h3 class="achiever-name">{achiever.name}</h3>
                            <p class="achiever-class">{achiever.year}</p>
                            <p class="achiever-desc">{achiever.achievements}</p>
                            
                            <div class="achiever-stats">
                                {achiever.stats.map(stat => (
                                    <div class="stat-item">
                                        <span class="stat-value">{stat.value}</span>
                                        <span class="stat-label">{stat.label}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── Notable Alumni ── -->
    <section class="fame-section bg-white pb-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label items-end text-right mb-10 ws-reveal">
                <span class="ab-label-eyebrow">Beyond Tshikhuthula</span>
                <h2 class="ab-label-heading">Notable Alumni</h2>
                <div class="ab-label-rule ml-auto"></div>
            </div>

            <div class="fame-grid mt-12">
                {notableAlumni.map((alumni, i) => (
                    <div class={`achiever-card border-none ws-reveal delay-${i+1}`} style="border-top: 4px solid #800000;">
                        <div class="achiever-badge bg-maroon-800">{alumni.role}</div>
                        <div class="achiever-image-container" style="aspect-ratio: 4/3;">
                            <img src={alumni.image} alt={alumni.name} class="achiever-image" style="object-position: center 20%;" />
                        </div>
                        <div class="achiever-content">
                            <h3 class="achiever-name">{alumni.name}</h3>
                            <p class="achiever-class text-maroon-800">{alumni.year}</p>
                            <p class="achiever-desc leading-relaxed">{alumni.bio}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

</Layout>

<script>
    function initReveal() {
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('reveal-active');
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.ws-reveal').forEach(el => observer.observe(el));
    }

    document.addEventListener('DOMContentLoaded', initReveal);
    document.addEventListener('astro:after-swap', initReveal);

    // Filtering Logic for Top Achievers
    function initFilters() {
        const filterBtns = document.querySelectorAll('.filter-btn');
        const cards = document.querySelectorAll('.achiever-card[data-year]');

        if (!filterBtns.length || !cards.length) return;

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // Update active button styles
                filterBtns.forEach(b => {
                    b.classList.remove('active', 'bg-primary-700', 'text-white', 'shadow-lg', 'border-primary-600');
                    b.classList.add('bg-slate-100', 'text-slate-500', 'border-slate-200');
                });
                
                btn.classList.add('active', 'bg-primary-700', 'text-white', 'shadow-lg', 'border-primary-600');
                btn.classList.remove('bg-slate-100', 'text-slate-500', 'border-slate-200');

                // Filter cards
                const filterValue = btn.getAttribute('data-filter');
                
                cards.forEach(card => {
                    // Reset animation for re-triggering
                    card.classList.remove('reveal-active');
                    
                    if (filterValue === 'all' || card.getAttribute('data-year') === filterValue) {
                        card.style.display = 'flex'; // Use flex as it matches the original CSS layout for these cards
                        // Small timeout to allow display:block to apply before re-adding animation class
                        setTimeout(() => {
                            card.classList.add('reveal-active');
                        }, 50);
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });
    }

    document.addEventListener('DOMContentLoaded', initFilters);
    document.addEventListener('astro:after-swap', initFilters);
</script>
