---
import Layout from '../layouts/Layout.astro';
import SecondaryNav from '../components/SecondaryNav.astro';
import eventsData from '../data/events.json';
import importantDatesData from '../data/importantDates.json';
import '../styles/calendar-events.css';

const formatDate = (date: string) => {
    const d = new Date(date);
    return {
        day: d.getDate(),
        month: d.toLocaleString('default', { month: 'short' }).toUpperCase(),
        year: d.getFullYear(),
        monthFull: d.toLocaleString('default', { month: 'long' })
    };
};

const monthNames = ["January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December"
];

const upcomingEvents = eventsData.slice(0, 6);

const getEventColor = (eventType: string) => {
    const colors: Record<string, string> = {
        'school_event': '#543717',
        'holiday': '#059669',
        'exam': '#cb8f24',
        'parent_meeting': '#3a2610',
        'other': '#64748b'
    };
    return colors[eventType] || '#64748b';
};

const getCategoryLabel = (category: string) => {
    const labels: Record<string, string> = {
        'academic': 'Academic',
        'sports': 'Sports',
        'cultural': 'Cultural',
        'parent': 'Parent',
        'other': 'General'
    };
    return labels[category] || 'General';
};

const getEventTypeLabel = (type: string) => {
  return type.replace(/_/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase());
};
---

<Layout title="School Calendar | Lotsha Primary School"
    description="Stay up to date with Lotsha Primary School academic calendar, upcoming events, parent meetings, sports days, and cultural activities." currentPage="calendar-events" noNavbarPadding={true} showMainNav={true}>
    <SecondaryNav currentPage="calendar-events" />

    <!-- Hero Header -->
    <header class="cal-header ws-reveal">
        <div class="cal-header-shimmer"></div>
        <div class="cal-header-bg"></div>
        <div class="cal-header-content">
            <div class="cal-badge">Schedule</div>
            <h1 class="cal-title">
                School <span class="cal-title-accent">Calendar & Events</span>
            </h1>
            <p class="cal-tagline">
                Stay updated with school activities, important dates, and upcoming events.
            </p>
            <div class="cal-stats">
                <div class="cal-stat">
                    <div class="cal-stat-num">{eventsData.length}</div>
                    <div class="cal-stat-label">Total Events</div>
                </div>
                <div class="cal-stat-divider"></div>
                <div class="cal-stat">
                    <div class="cal-stat-num">{upcomingEvents.length}</div>
                    <div class="cal-stat-label">Upcoming</div>
                </div>
                <div class="cal-stat-divider"></div>
                <div class="cal-stat">
                    <div class="cal-stat-num">{importantDatesData.length}</div>
                    <div class="cal-stat-label">Important Dates</div>
                </div>
            </div>
        </div>
    </header>

    <!-- ── Main Content ── -->
    <div class="cal-page-bg">
        <div class="cal-sections">

            <!-- Calendar Section -->
            <section class="cal-section-card">
                <div class="cal-card-header">
                    <h2 id="calendar-title" class="cal-card-title">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        Loading...
                    </h2>
                    <div class="cal-nav-btns">
                        <button class="cal-nav-btn" id="prevMonth">← Prev</button>
                        <button class="cal-nav-btn active" id="goToday">Today</button>
                        <button class="cal-nav-btn" id="nextMonth">Next →</button>
                    </div>
                </div>

                <div class="cal-grid-wrap">
                    <div class="cal-weekdays">
                        {["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"].map(day => (
                            <div class="cal-weekday">{day}</div>
                        ))}
                    </div>
                    <div class="cal-days" id="calendarDays">
                        <!-- Generated by JS -->
                    </div>
                </div>

                <!-- Legend -->
                <div class="cal-legend">
                    <div class="cal-legend-item">
                        <span class="cal-legend-dot" style="background:#543717"></span> School Event
                    </div>
                    <div class="cal-legend-item">
                        <span class="cal-legend-dot" style="background:#059669"></span> Holiday
                    </div>
                    <div class="cal-legend-item">
                        <span class="cal-legend-dot" style="background:#cb8f24"></span> Exam
                    </div>
                    <div class="cal-legend-item">
                        <span class="cal-legend-dot" style="background:#3a2610"></span> Parent Meeting
                    </div>
                </div>
            </section>

            <!-- Upcoming Events Section -->
            <section>
                <div class="cal-section-heading">
                    <span class="cal-section-label">School Programme</span>
                    <h2>Upcoming Events</h2>
                    <div class="cal-section-rule"></div>
                </div>

                <div class="cal-events-grid" id="eventsGrid">
                    {upcomingEvents.map((event, i) => (
                        <div class={`cal-event-card`} style={`animation-delay:${0.1 * i}s`}>
                            <div class="cal-event-date" style={`background: ${getEventColor(event.event_type)}`}>
                                <span class="cal-event-day">{formatDate(event.event_date).day}</span>
                                <span class="cal-event-month">{formatDate(event.event_date).month}</span>
                                <span class="cal-event-year">{formatDate(event.event_date).year}</span>
                            </div>
                            <div class="cal-event-body">
                                <div class="cal-event-meta">
                                    <span class="cal-event-category">{getCategoryLabel(event.category)}</span>
                                    <span class="cal-event-type" style={`color: ${getEventColor(event.event_type)}`}>
                                        ● {getEventTypeLabel(event.event_type)}
                                    </span>
                                </div>
                                <h3 class="cal-event-title">{event.title}</h3>
                                <div class="cal-event-details">
                                    <span class="cal-event-detail">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                        {event.start_time}{event.end_time ? ` – ${event.end_time}` : ''}
                                    </span>
                                    {event.location && (
                                        <span class="cal-event-detail">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            </svg>
                                            {event.location}
                                        </span>
                                    )}
                                </div>
                                <p class="cal-event-desc">{event.description}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </section>

        </div>
    </div>
</Layout>

<script define:vars={{ eventsData, monthNames }}>
    let currentMonth = new Date().getMonth();
    let currentYear = new Date().getFullYear();

    const calendarTitle = document.getElementById('calendar-title');
    const calendarDays = document.getElementById('calendarDays');
    const prevMonthBtn = document.getElementById('prevMonth');
    const nextMonthBtn = document.getElementById('nextMonth');
    const todayBtn = document.getElementById('goToday');

    function getEventColor(eventType) {
        const colors = {
            'school_event': '#543717',
            'holiday': '#059669',
            'exam': '#cb8f24',
            'parent_meeting': '#3a2610',
            'other': '#64748b'
        };
        return colors[eventType] || '#64748b';
    }

    function renderCalendar(month, year) {
        if (!calendarDays || !calendarTitle) return;

        calendarDays.innerHTML = '';
        calendarTitle.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:1.25rem;height:1.25rem;flex-shrink:0">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            ${monthNames[month]} ${year}`;

        const firstDay = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();

        // Empty cells before first day
        for (let i = 0; i < firstDay; i++) {
            const cell = document.createElement('div');
            cell.className = 'cal-day empty';
            calendarDays.appendChild(cell);
        }

        const today = new Date();
        const todayStr = `${today.getFullYear()}-${(today.getMonth() + 1).toString().padStart(2, '0')}-${today.getDate().toString().padStart(2, '0')}`;

        for (let i = 1; i <= daysInMonth; i++) {
            const dateStr = `${year}-${(month + 1).toString().padStart(2, '0')}-${i.toString().padStart(2, '0')}`;
            const isToday = dateStr === todayStr;
            const dayEvents = eventsData.filter(e => e.event_date === dateStr);

            const cell = document.createElement('div');
            cell.className = `cal-day${isToday ? ' today' : ''}${dayEvents.length ? ' has-event' : ''}`;
            cell.title = dayEvents.map(e => e.title).join(', ') || '';

            const numEl = document.createElement('span');
            numEl.className = 'cal-day-num';
            numEl.textContent = i;
            cell.appendChild(numEl);

            if (dayEvents.length > 0) {
                const dots = document.createElement('div');
                dots.className = 'cal-day-dots';
                dayEvents.slice(0, 3).forEach(e => {
                    const dot = document.createElement('span');
                    dot.className = 'cal-day-dot';
                    dot.style.background = getEventColor(e.event_type);
                    dots.appendChild(dot);
                });
                cell.appendChild(dots);
            }

            calendarDays.appendChild(cell);
        }
    }

    if (prevMonthBtn) prevMonthBtn.onclick = () => {
        currentMonth--;
        if (currentMonth < 0) { currentMonth = 11; currentYear--; }
        renderCalendar(currentMonth, currentYear);
    };
    if (nextMonthBtn) nextMonthBtn.onclick = () => {
        currentMonth++;
        if (currentMonth > 11) { currentMonth = 0; currentYear++; }
        renderCalendar(currentMonth, currentYear);
    };
    if (todayBtn) todayBtn.onclick = () => {
        currentMonth = new Date().getMonth();
        currentYear = new Date().getFullYear();
        renderCalendar(currentMonth, currentYear);
    };

    renderCalendar(currentMonth, currentYear);
    document.addEventListener('astro:after-swap', () => renderCalendar(currentMonth, currentYear));
</script>
