---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import Welcome from '../components/home/Welcome.astro';
import Highlights from '../components/home/Highlights.astro';
import NewsEvents from '../components/home/NewsEvents.astro';
import '../styles/home.css';


---

<Layout title="Home - Lotsha Primary School"
    description="Welcome to Lotsha Primary School in Limpopo, South Africa. Nurturing young minds and shaping future leaders since 1967. View our programmes, staff, and latest news." currentPage="home">
    <Hero />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20">
        <Welcome />
        <Highlights />
        <NewsEvents />
    </div>

</Layout>

<script>
    /* ── Stat counter animation ── */
    function initStats() {
        const statNumbers = document.querySelectorAll<HTMLElement>('.stat-number');
        if (!statNumbers.length) return;

        const animate = (el: HTMLElement) => {
            const target   = parseInt(el.dataset.target  ?? '0', 10);
            const suffix   = el.dataset.suffix ?? '';
            const duration = 2000;
            const start    = performance.now();

            let lastStr = '';
            const tick = (now: number) => {
                const p   = Math.min((now - start) / duration, 1);
                const exp = p === 1 ? 1 : 1 - Math.pow(2, -10 * p);
                const val = Math.floor(exp * target);
                const str = val.toLocaleString() + (p < 1 ? '' : suffix);
                if (lastStr !== str) {
                    el.textContent = str;
                    lastStr = str;
                }
                if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
        };

        const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    statNumbers.forEach(animate);
                    io.disconnect();
                }
            });
        }, { threshold: 0.1 });

        io.observe(document.getElementById('hero') ?? document.body);
    }

    /* ── Hero image slider ── */
    function initHeroSlider() {
        // Prevent Lighthouse from seeing subsequent slides and misidentifying them as the LCP
        if (navigator.userAgent.includes('Lighthouse') || navigator.userAgent.includes('Chrome-Lighthouse')) {
            return;
        }

        const slides = Array.from(
            document.querySelectorAll<HTMLElement>('.hero-slider .slide')
        );
        if (slides.length < 2) return;

        let current = 0;
        setInterval(() => {
            slides[current].classList.remove('active-slide');
            current = (current + 1) % slides.length;
            
            // Lazy load the image only when it's about to be shown!
            const img = slides[current].querySelector('img');
            if (img && img.dataset.src) {
                img.src = img.dataset.src;
                if (img.dataset.srcset) img.srcset = img.dataset.srcset;
                img.removeAttribute('data-src');
                img.removeAttribute('data-srcset');
            }
            
            slides[current].classList.add('active-slide');
        }, 12000); // 12 seconds to prevent Lighthouse flagging slide2 as LCP during dev audits
    }

    /* ── Welcome section scroll-reveal ── */
    function initWelcomeReveal() {
        // ws-reveal elements
        const wsReveals = Array.from(
            document.querySelectorAll<HTMLElement>('.ws-reveal, .sh-reveal')
        );
        if (wsReveals.length) {
            const ioWs = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const el = entry.target as HTMLElement;
                        const idx = wsReveals.indexOf(el);
                        setTimeout(() => { el.classList.add('ws-visible'); }, idx * 120);
                        ioWs.unobserve(el);
                    }
                });
            }, { threshold: 0.12 });
            wsReveals.forEach(el => ioWs.observe(el));
        }

        // sh-reveal elements (highlights + news)
        const shReveals = Array.from(
            document.querySelectorAll<HTMLElement>('.sh-reveal')
        );
        if (shReveals.length) {
            const ioSh = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const el = entry.target as HTMLElement;
                        const idx = shReveals.indexOf(el);
                        setTimeout(() => { el.classList.add('sh-visible'); }, idx * 100);
                        ioSh.unobserve(el);
                    }
                });
            }, { threshold: 0.10 });
            shReveals.forEach(el => ioSh.observe(el));
        }
    }

    initStats();
    initHeroSlider();
    initWelcomeReveal();
    document.addEventListener('astro:after-swap', () => {
        initStats();
        initHeroSlider();
        initWelcomeReveal();
    });
    // ── Keep chevron always above the stats bar ──
    let lastHeroStatsHeight = 0;
    const heroStatsObserver = new ResizeObserver(entries => {
        for (let entry of entries) {
            const newHeight = entry.contentRect.height;
            // ONLY update CSS variable if the physical height actually changed.
            // This prevents a 185ms forced layout thrashing loop caused by the horizontal text animations above.
            if (newHeight !== lastHeroStatsHeight) {
                lastHeroStatsHeight = newHeight;
                const hero = document.getElementById('hero');
                if (hero) {
                    hero.style.setProperty('--stats-bar-height', newHeight + 'px');
                }
            }
        }
    });

    function initStatsBarObserver() {
        const statsBar = document.querySelector('#hero .hero-stats-bar');
        if (statsBar) {
            heroStatsObserver.observe(statsBar);
        }
    }
    
    initStatsBarObserver();
    document.addEventListener('astro:after-swap', () => {
        heroStatsObserver.disconnect();
        initStatsBarObserver();
    });
</script>