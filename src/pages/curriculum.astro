---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import SecondaryNav from '../components/SecondaryNav.astro';
import '../styles/curriculum.css';

const fetStreams = [
    {
        title: "Sciences Stream",
        type: "science",
        description: "For learners aspiring towards careers in medicine, engineering, agriculture, and applied sciences.",
        subjects: [
            "Mathematics",
            "Physical Sciences",
            "Life Sciences",
            "Agricultural Sciences",
            "Geography"
        ]
    },
    {
        title: "Commerce Stream",
        type: "commerce",
        description: "Designed for future entrepreneurs, accountants, and business leaders in the modern economy.",
        subjects: [
            "Mathematics / Mathematical Literacy",
            "Accounting",
            "Business Studies",
            "Economics"
        ]
    },
    {
        title: "Humanities Stream",
        type: "humanities",
        description: "Fostering critical thinking for careers in law, education, social sciences, and public administration.",
        subjects: [
            "Mathematical Literacy",
            "History",
            "Geography",
            "Life Orientation",
            "Tshivenda Home Language",
            "English First Additional Language"
        ]
    }
];

const getSubjects = [
    "Mathematics",
    "Natural Sciences",
    "Social Sciences",
    "Technology",
    "Economic Management Sciences (EMS)",
    "Creative Arts",
    "Life Orientation",
    "Tshivenda Home Language",
    "English First Additional Language"
];
---

<Layout title="Curriculum - Lotsha Primary School"
    description="Explore the CAPS-aligned curriculum at Lotsha Primary School. Our structured programmes aim to provide every learner with a world-class education from Grade R to Grade 7." currentPage="curriculum" noNavbarPadding={true} showMainNav={true}>
    
    <!-- ── Page Header ── -->
    <header class="curriculum-header ws-reveal">
        <div class="curriculum-header-bg"></div>
        <div class="curriculum-header-content">
            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full border border-gold-500/30 bg-gold-500/10 backdrop-blur-md mb-6">
                <span class="page-eyebrow">Academic Excellence</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-heading text-white font-display drop-shadow-lg tracking-tight">
                Our <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-gold-600">Curriculum</span>
            </h1>
            <p class="page-tagline">
                CAPS-aligned learning · Critical thinking · Academic excellence
            </p>
        </div>
    </header>

    <!-- ── FET Phase (Grades 10-12) ── -->
    <section class="phase-section dark-section">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label ws-reveal text-center items-center">
                <span class="ab-label-eyebrow">Further Education and Training</span>
                <h2 class="ab-label-heading">FET Phase (Grades 10-12)</h2>
                <div class="ab-label-rule mx-auto"></div>
                <p class="max-w-2xl mx-auto text-slate-400 mt-6 font-lato">
                    Learners in Grade 10 MUST choose a specific subject stream to specialize in for their final Matriculation examinations. ALL streams include four compulsory subjects: Tshivenda HL, English FAL, Mathematics/Math Lit, and Life Orientation.
                </p>
            </div>

            <div class="stream-grid">
                {fetStreams.map((stream, i) => (
                    <div class={`stream-card ${stream.type} ws-reveal delay-${i+1}`}>
                        <h3 class="stream-title">{stream.title}</h3>
                        <p class="stream-desc">{stream.description}</p>
                        
                        <h4 class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-4">Focus Subjects:</h4>
                        <ul class="subject-list">
                            {stream.subjects.map(subject => (
                                <li class="subject-item">
                                    <svg class="subject-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    {subject}
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── GET Phase (Grades 8-9) ── -->
    <section class="phase-section">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label ws-reveal">
                <span class="ab-label-eyebrow">General Education and Training</span>
                <h2 class="ab-label-heading">GET Phase (Grades 8-9)</h2>
                <div class="ab-label-rule"></div>
                <p class="max-w-3xl text-slate-600 mt-6 font-lato leading-relaxed">
                    The GET phase provides a broad, foundational education exposing learners to a wide variety of disciplines. This ensures they have the foundational knowledge required to make an informed choice regarding their FET subject streams in Grade 10. All subjects in this phase are compulsory.
                </p>
            </div>

            <div class="base-subject-grid">
                {getSubjects.map((subject, i) => (
                    <div class="base-subject-card ws-reveal transform transition-all duration-300" style={`transition-delay: ${i * 50}ms`}>
                        <h4>{subject}</h4>
                    </div>
                ))}
            </div>
            
            <div class="mt-20 p-8 md:p-12 bg-maroon-900 rounded-[2rem] text-center ws-reveal text-white shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 bg-[url('/assets/images/grid.svg')] opacity-10"></div>
                <div class="relative z-10">
                    <h3 class="text-2xl font-heading mb-4 text-gold-400">Academic Support Programs</h3>
                    <p class="max-w-3xl mx-auto font-lato text-slate-200 leading-relaxed mb-6">
                        We offer afternoon extra classes, weekend study camps for Grade 12s, and peer-tutoring initiatives to ensure no learner is left behind in their academic journey.
                    </p>
                    <a href="/contact" class="inline-block px-8 py-3 bg-gold-500 text-maroon-900 font-bold uppercase tracking-wider rounded text-sm hover:bg-gold-400 transition-colors shadow-lg">Enquire Full Syllabus</a>
                </div>
            </div>
        </div>
    </section>

</Layout>


<ScrollReveal />

